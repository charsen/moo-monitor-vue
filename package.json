{
  "name": "moo-monitor-vue",
  "version": "0.2.0",
  "description": "轻量 Vue 3 前端异常监控 SDK —— 捕获浏览器 JS 错误并上报到 Moo Scaffold Cloud。",
  "type": "module",
  "license": "MIT",
  "author": "charsen",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/charsen/moo-monitor-vue.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "error-monitoring",
    "exception",
    "sentry",
    "frontend",
    "observability"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier -w .",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.4",
    "vue": "^3.5.12"
  },
  "engines": {
    "node": ">=18"
  }
}
